Bootstrap: docker
From: nvcr.io/nvidia/pytorch:24.10-py3

%labels
Author cooperjohn
Version v0.1
Description "Baseline eval environment for Isambard (arm64 + NVIDIA)"

%environment
export PATH=/opt/venv/bin:$PATH
export HF_HOME=/scratch/u5fi/byebyevlad.u5fi/hf_cache
export HF_DATASETS_CACHE=${HF_HOME}/hd
export HF_HUB_CACHE=${HF_HOME}/hub
export TRANSFORMERS_CACHE=${HF_HOME}/transformers
export PYTHONUNBUFFERED=1

%post
apt-get update && \
apt-get install -y --no-install-recommends \
python3-dev python3-pip python3-venv \
git curl ca-certificates \
build-essential cmake ninja-build pkg-config && \
rm -rf /var/lib/apt/lists/*

python -m pip install --upgrade pip setuptools wheel

# Install your Python packages here
python -m pip install \
numpy scipy pandas scikit-learn tqdm pyyaml \
huggingface_hub datasets transformers accelerate \
torch torchvision sentence-transformers

%runscript
exec "$@"